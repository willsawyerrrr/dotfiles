#!/usr/bin/env zsh
#
# add-completion <name>
#
# Reads a zsh completion script from stdin and installs it as an
# oh-my-zsh custom plugin at
# ${DOTFILES_DIR}/dot-config/omz_custom/plugins/<name>/<name>.plugin.zsh.
#
# The plugin is picked up automatically by the glob in .zshrc:
#   plugins+=(${ZSH_CUSTOM}/plugins/*(N/:t))
#
# Usage:
#   <tool> completion zsh | add-completion <tool>

set -e

if (( $# != 1 )); then
    print -u2 "usage: add-completion <name>"
    exit 2
fi

name="$1"

if [[ ! $name =~ '^[a-zA-Z0-9_-]+$' ]]; then
    print -u2 "add-completion: invalid name '$name'"
    exit 2
fi

if [[ -t 0 ]]; then
    print -u2 "add-completion: stdin must be the completion script (pipe or redirect)"
    exit 2
fi

dotfiles="${DOTFILES_DIR:-${HOME}/dotfiles}"
plugin_dir="${dotfiles}/dot-config/omz_custom/plugins/${name}"
plugin_file="${plugin_dir}/${name}.plugin.zsh"

if [[ -e $plugin_file ]]; then
    print -u2 "add-completion: ${plugin_file} already exists"
    exit 1
fi

mkdir -p -- "$plugin_dir"
cat > "$plugin_file"

print "wrote ${plugin_file}"
