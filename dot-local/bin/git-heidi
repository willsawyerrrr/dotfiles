#!/usr/bin/env zsh
#
# git heidi [<git-clone-option> ...] <repo>
#
# Clones <repo> bare into <repo>/.bare and sets up <repo>/.git so the directory
# behaves like a normal clone — ready for worktrees (e.g. git-wt) to live
# under <repo>/. Only the default branch is tracked; fetch others on demand
# with `git fetch origin <branch>:refs/remotes/origin/<branch>`.

set -e

repo="${@[-1]}"
set -- "${@[1,-2]}"

git clone --bare --single-branch "$@" "git@github.com:oscerai/${repo}.git" "${repo}/.bare"
cd "${repo}"

print "gitdir: ./.bare" > .git
default=$(git symbolic-ref --short HEAD)
git config remote.origin.fetch "+refs/heads/${default}:refs/remotes/origin/${default}"
git config wt.basedir '..'
git fetch origin
