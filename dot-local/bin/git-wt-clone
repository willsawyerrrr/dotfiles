#!/usr/bin/env zsh
#
# git wt-clone [<git-clone-option> ...] <url> <dir>
#
# Clones <url> bare into <dir>/.bare and sets up <dir>/.git so the directory
# behaves like a normal clone — ready for worktrees (e.g. git-wt) to live
# under <dir>/. All remote branches are tracked under refs/remotes/origin/*;
# local branches (refs/heads/*) only exist for the worktrees you create. An
# initial worktree is created for the default branch.

set -e

dir="${@[-1]:-}"
url="${@[-2]:-}"
if [[ -z "$url" ]] || [[ -z "$dir" ]] || [[ "$url" == -* ]] || [[ "$dir" == -* ]]; then
  print -u2 "usage: git wt-clone [<git-clone-option> ...] <url> <dir>"
  exit 2
fi
set -- "${@[1,-3]}"

git clone --bare "$@" "${url}" "${dir}/.bare"
cd "${dir}"

print "gitdir: ./.bare" > .git
git config remote.origin.fetch '+refs/heads/*:refs/remotes/origin/*'
git fetch origin

# `git clone --bare` mirrored every remote branch into refs/heads/*; keep
# only the default (which the initial worktree will use) and drop the rest.
default=$(git symbolic-ref --short HEAD)
git for-each-ref --format='%(refname)' refs/heads/ \
  | grep -vxF "refs/heads/${default}" \
  | sed 's/^/delete /' \
  | git update-ref --stdin

git wt "${default}"
