#!/usr/bin/env zsh
#
# open-linear-issue-in-nvim <branch> <prompt>

branch="$1"
prompt="$2"

worktree_dir=$(git wt "${branch}")

run-in-kitty "${worktree_dir}" nvim -c "ClaudeCodePrompt ${prompt}" .

# Close the tab Linear opened to run this script; nvim is now in its own tab.
kitty @ close-window --self
