{
  "cleanupPeriodDays": 7,
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Glob",
      "Grep",
      "Read",
      "Skill",
      "WebFetch",
      "WebSearch",
      "Write",
      "mcp__claude_ai_Datadog",
      "mcp__claude_ai_Jamf_Pro",
      "mcp__claude_ai_Linear",
      "mcp__claude_ai_Notion",
      "mcp__claude_ai_Slack",
      "mcp__plugin_posthog_posthog__exec"
    ],
    "ask": [
      "Bash(gh pr merge *)",
      "Bash(rm -f*)",
      "Bash(rm -r*)",
      "mcp__claude_ai_Slack__slack_create_canvas",
      "mcp__claude_ai_Slack__slack_schedule_message",
      "mcp__claude_ai_Slack__slack_send_message",
      "mcp__claude_ai_Slack__slack_update_canvas"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "NAME=$(jq -r .name); git wt --nocd $NAME"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "WORKTREE_PATH=$(jq -r .worktree_path); git wt -d $WORKTREE_PATH"
          }
        ]
      }
    ]
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": false,
  "defaultShell": "bash",
  "statusLine": {
    "type": "command",
    "command": "/Users/willsawyerrrr/go/bin/claudewatch"
  },
  "enabledPlugins": {
    "claudewatch@claudewatch": true,
    "lua-lsp@claude-plugins-official": true,
    "posthog@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claudewatch": {
      "source": {
        "source": "github",
        "repo": "nitintf/claudewatch"
      }
    }
  },
  "syntaxHighlightingDisabled": false,
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "voiceEnabled": true
}
