{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AeroSpace source config",
  "description": "Processed into aerospace.toml by scripts/gen-aerospace-config.py",
  "type": "object",
  "additionalProperties": false,
  "required": ["generator", "aerospace", "key-mapping", "gaps", "mode"],
  "properties": {
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["directions", "workspace-monitors", "workspace-apps"],
      "properties": {
        "directions": {
          "description": "Map of vim key (h/j/k/l) to AeroSpace direction name. Used to expand {dir_key}/{dir} templates.",
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": ["left", "right", "up", "down"]
          }
        },
        "workspace-monitors": {
          "description": "Map of workspace number to monitor assignment. Keys become the workspace list; values become workspace-to-monitor-force-assignment.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "workspace-apps": {
          "description": "Map of app bundle ID to workspace number. Expands into on-window-detected rules.",
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        }
      }
    },
    "aerospace": {
      "description": "Top-level AeroSpace settings, lifted to the root of the generated config.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start-at-login": { "type": "boolean" },
        "after-login-command": {
          "type": "array",
          "items": { "type": "string" }
        },
        "after-startup-command": {
          "type": "array",
          "items": { "type": "string" }
        },
        "exec-on-workspace-change": {
          "description": "Command run on workspace change. $AEROSPACE_FOCUSED_WORKSPACE and $AEROSPACE_PREV_WORKSPACE are set.",
          "type": "array",
          "items": { "type": "string" }
        },
        "accordion-padding": {
          "description": "Padding between accordion windows in pixels. Set to 0 to disable.",
          "type": "integer",
          "minimum": 0
        },
        "default-root-container-layout": {
          "type": "string",
          "enum": ["tiles", "accordion"]
        },
        "automatically-unhide-macos-hidden-apps": { "type": "boolean" }
      }
    },
    "key-mapping": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preset": {
          "type": "string",
          "enum": ["qwerty", "dvorak"]
        }
      }
    },
    "gaps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inner": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "horizontal": { "type": "integer", "minimum": 0 },
            "vertical": { "type": "integer", "minimum": 0 }
          }
        },
        "outer": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "left":   { "$ref": "#/$defs/gapValue" },
            "right":  { "$ref": "#/$defs/gapValue" },
            "top":    { "$ref": "#/$defs/gapValue" },
            "bottom": { "$ref": "#/$defs/gapValue" }
          }
        }
      }
    },
    "mode": {
      "description": "Binding modes. 'main' is the default; additional modes can be defined freely.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/bindingMode"
      }
    }
  },
  "$defs": {
    "command": {
      "description": "A single AeroSpace command string, or an array of commands to run in sequence.",
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      ]
    },
    "gapValue": {
      "description": "A constant gap in pixels, or a per-monitor array ending with a default integer.",
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "integer", "minimum": 0 },
              { "type": "object" }
            ]
          }
        }
      ]
    },
    "bindingMode": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "binding": {
          "description": "Key bindings for this mode. Keys are key combos (bare or quoted for templates like \"alt-{ws}\").",
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/command" }
        }
      }
    }
  }
}
