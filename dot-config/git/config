[alias]
	# Clone aliases
	heidi = !git clone git@github.com:oscerai/$1.git
	personal = !git clone git@github.com:willsawyerrrr/$1.git

	# Commit aliases
	amend = commit --amend --no-edit
	empty = commit --allow-empty

	# Log aliases
	l = log --oneline

[commit]
	gpgsign = true

[core]
	editor = nvim
	excludesFile = "~/.config/git/ignore"
	pager = delta

[fetch]
	prune = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	process = git-lfs filter-process
	required = true
	smudge = git-lfs smudge -- %f

[gpg]
	format = ssh

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

[submodule]
	recurse = true

[tag]
	gpgSign = true

